# Caddyfile — auto-TLS, fallback-сайт, проксирование подписки и Marzban API.
# CF-subdomain блок вынесен в caddy/Caddyfile.cf и подключается через import,
# чтобы пустой CF_SUBDOMAIN не валил весь Caddy.

{$SERVER_DOMAIN} {
    encode gzip

    # 1) Subscription URL — наш aiohttp-сервер (port 8081 на host)
    @sub path /sub/* /sub4/* /sub6/* /links/*
    handle @sub {
        reverse_proxy 127.0.0.1:8081
    }

    # 2) Marzban admin API + dashboard
    @marzban path /api/* /dashboard/*
    handle @marzban {
        reverse_proxy 127.0.0.1:8000
    }

    # 3) VLESS+XHTTP fallback. Xray слушает 127.0.0.1:2087.
    # Caddy терминирует TLS на 443 и проксирует только path=/xhttp на Xray.
    # Этот трафик выглядит как обычный HTTPS к нашему сайту → DPI не отличает.
    @xhttp path /xhttp /xhttp/*
    handle @xhttp {
        reverse_proxy 127.0.0.1:2087
    }

    # 4) Healthcheck
    handle /healthz {
        reverse_proxy 127.0.0.1:8081
    }

    # 5) Всё остальное — фейковый сайт-визитка (маскировка)
    handle {
        root * /srv
        file_server
        try_files {path} /index.html
    }
}

# Опциональный CF-subdomain (gRPC over Cloudflare). Файл Caddyfile.cf
# генерируется setup_caddy.sh ТОЛЬКО если в .env задан CF_SUBDOMAIN.
# Glob-import: если файла нет (или пустой) — Caddy просто пропустит.
import /etc/caddy/Caddyfile.cf*

# HTTP -> HTTPS redirect
:80 {
    redir https://{host}{uri} permanent
}
