# Marzban configuration. Скопируй в marzban/.env и заполни.
# Полный список переменных: https://github.com/Gozargah/Marzban

SUDO_USERNAME=admin
SUDO_PASSWORD=

UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000

# Доступ только локально — наружу проксируем через Caddy с allowlist
DASHBOARD_PATH=/dashboard/
DOCS=true

# Хранилище: SQLite по умолчанию (для одного сервера ок).
# Если планируется кластер — переключить на mysql/postgres.
SQLALCHEMY_DATABASE_URL=sqlite:////var/lib/marzban/db.sqlite3

# Subscription
XRAY_SUBSCRIPTION_URL_PREFIX=https://vpn.example.com
SUBSCRIPTION_PAGE_LANG=ru
