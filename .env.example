# ===== Telegram =====
BOT_TOKEN=
OWNER_ID=
# polling | webhook
RUN_MODE=polling
WEBHOOK_URL=
WEBHOOK_SECRET=

# ===== Database =====
DATABASE_URL=postgresql+asyncpg://vlessich:vlessich@postgres:5432/vlessich

# ===== Redis =====
REDIS_URL=redis://redis:6379/0

# ===== Marzban API =====
# Внутренний URL панели (docker network): http://marzban:8000
MARZBAN_API_URL=http://marzban:8000
MARZBAN_USERNAME=admin
MARZBAN_PASSWORD=
# Время жизни access-токена (минут). Marzban по умолчанию 1440.
MARZBAN_TOKEN_TTL_MIN=1440

# ===== Server / domain =====
SERVER_DOMAIN=vpn.example.com
SERVER_IP=
# Порт публичной подписки (Caddy слушает 443 и проксирует /sub/)
SUBSCRIPTION_PUBLIC_PORT=443
# Внутренний aiohttp-сервер подписки
SUB_HOST=0.0.0.0
SUB_PORT=8081

# ===== Reality / SNI =====
# Список SNI-доноров через запятую. Используется как fallback,
# если таблица sni_donors пуста.
SNI_DONORS=www.microsoft.com,www.cloudflare.com,github.com
SHORT_ID_ROTATION_DAYS=7

# ===== Honeypot =====
HONEYPOT_ENABLED=true
HONEYPOT_PORT=8080

# ===== Monitoring =====
MONITOR_INTERVAL_MIN=10
EXPIRATION_INTERVAL_MIN=5
ANTIFILTER_REFRESH_HOURS=24

# ===== Antifilter (RU subnets for split-tunnel) =====
ANTIFILTER_URL=https://antifilter.download/list/subnet.lst

# ===== Bot business rules =====
TRIAL_ENABLED=true
TRIAL_DURATION_HOURS=24
MAX_CONNECTIONS_TRIAL=1
MAX_CONNECTIONS_CODE=5

# ===== Antispam =====
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_SEC=10
AUTH_MAX_ATTEMPTS=3
AUTH_BLOCK_MINUTES=15
